                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{operatorApiBaseUrl}}/operators",
              "host": [
                "{{operatorApiBaseUrl}}"
              ],
              "path": [
                "operators"
              ]
            },
            "description": "Admin-only through the gateway. If you do not have an admin JWT, either paste one into `adminToken` or change `operatorApiBaseUrl` to `http://localhost:8082` and hit the service directly for local testing."
          },
          "response": []
