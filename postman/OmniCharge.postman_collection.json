{
  "info": {
    "name": "OmniCharge API Collection",
    "_postman_id": "0e601a58-e74e-487a-a255-4f911671f546",
    "description": "Postman collection for OmniCharge business APIs.\n\nRecommended order:\n1. Auth -> Register User\n2. Auth -> Login User\n3. Operator Service -> Create Operator (requires adminToken when routed through gateway)\n4. Operator Service -> Create Plan (requires adminToken when routed through gateway)\n5. Recharge Service -> Create Recharge\n6. Payment Service requests as needed\n\nNotes:\n- `notification-service` currently exposes no public REST controller, so it has no request in this collection.\n- `Create Operator`, `Delete Operator`, `Create Plan`, and `Delete Plan` require `ROLE_ADMIN` when called through the API Gateway. Paste a valid admin JWT into `adminToken`, or point `operatorApiBaseUrl` directly at `http://localhost:8082` for local testing.\n- Default URLs target the API Gateway. Edit the collection variables if you want to hit services directly.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [],
  "variable": [
    {
      "key": "gatewayBaseUrl",
      "value": "http://localhost:9090"
    },
    {
      "key": "userApiBaseUrl",
      "value": "http://localhost:9090/user-service"
    },
    {
      "key": "operatorApiBaseUrl",
      "value": "http://localhost:9090/operator-service"
    },
    {
      "key": "rechargeApiBaseUrl",
      "value": "http://localhost:9090/recharge-service"
    },
    {
      "key": "paymentApiBaseUrl",
      "value": "http://localhost:9090/payment-service"
    },
    {
      "key": "userServiceUrl",
      "value": "http://localhost:8081"
    },
    {
      "key": "operatorServiceUrl",
      "value": "http://localhost:8082"
    },
    {
      "key": "rechargeServiceUrl",
      "value": "http://localhost:8083"
    },
    {
      "key": "paymentServiceUrl",
      "value": "http://localhost:8084"
    },
    {
      "key": "userEmail",
      "value": "omnicharge.user@example.com"
    },
    {
      "key": "userPassword",
      "value": "Password@123"
    },
    {
      "key": "userName",
      "value": "OmniCharge User"
    },
    {
      "key": "userToken",
      "value": ""
    },
    {
      "key": "adminToken",
      "value": "PASTE_ADMIN_JWT_HERE"
    },
    {
      "key": "operatorId",
      "value": "1"
    },
    {
      "key": "planId",
      "value": "1"
    },
    {
      "key": "rechargeId",
      "value": "1"
    },
    {
      "key": "paymentId",
      "value": "1"
