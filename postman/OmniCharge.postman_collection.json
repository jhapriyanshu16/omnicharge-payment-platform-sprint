    {
      "name": "Recharge Service",
      "item": [
        {
          "name": "Create Recharge",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Create recharge request completed\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "if (json && json.data && json.data.rechargeId) {",
                  "    pm.collectionVariables.set(\"rechargeId\", String(json.data.rechargeId));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{userToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobileNumber\": \"{{mobileNumber}}\",\n  \"operatorId\": {{operatorId}},\n  \"planId\": {{planId}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{rechargeApiBaseUrl}}/recharges",
              "host": [
                "{{rechargeApiBaseUrl}}"
              ],
              "path": [
                "recharges"
              ]
            },
            "description": "Creates a recharge for the authenticated user. The API Gateway injects the `X-User-Email` header into recharge-service."
          },
          "response": []
        },
        {
          "name": "Get Recharge By Id",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{userToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{rechargeApiBaseUrl}}/recharges/{{rechargeId}}",
              "host": [
                "{{rechargeApiBaseUrl}}"
              ],
              "path": [
                "recharges",
                "{{rechargeId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Recharge Status",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{userToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "url": {
              "raw": "{{rechargeApiBaseUrl}}/recharges/{{rechargeId}}/status?status=SUCCESS",
              "host": [
                "{{rechargeApiBaseUrl}}"
              ],
              "path": [
                "recharges",
                "{{rechargeId}}",
                "status"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "SUCCESS"
                }
              ]
            },
            "description": "Allowed values come from the recharge-service enum, for example `PENDING`, `SUCCESS`, or `FAILED`."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Payment Service",
      "item": [
        {
          "name": "Create Payment",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Create payment request completed\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "if (json && json.data && json.data.transactionId) {",
                  "    pm.collectionVariables.set(\"paymentId\", String(json.data.transactionId));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{userToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rechargeId\": {{rechargeId}},\n  \"amount\": 299.0,\n  \"userEmail\": \"{{userEmail}}\",\n  \"operatorName\": \"Jio\",\n  \"planName\": \"28 Days 1.5GB/Day\",\n  \"mobileNumber\": \"{{mobileNumber}}\",\n  \"correlationId\": \"corr-{{$timestamp}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{paymentApiBaseUrl}}/payments",
              "host": [
                "{{paymentApiBaseUrl}}"
              ],
              "path": [
                "payments"
              ]
            },
            "description": "Direct payment creation request. In the normal recharge flow, recharge-service also calls payment-service internally."
          },
          "response": []
        },
        {
          "name": "Get Payment By Id",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{userToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{paymentApiBaseUrl}}/payments/{{paymentId}}",
              "host": [
                "{{paymentApiBaseUrl}}"
              ],
              "path": [
                "payments",
                "{{paymentId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Verify Payment",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{userToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "url": {
              "raw": "{{paymentApiBaseUrl}}/payments/verify/{{paymentId}}",
              "host": [
                "{{paymentApiBaseUrl}}"
              ],
              "path": [
                "payments",
                "verify",
                "{{paymentId}}"
              ]
            }
          },
          "response": []
        }
      ]
    }
