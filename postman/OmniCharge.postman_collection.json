    {
      "key": "mobileNumber",
      "value": "9876543210"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Register user request succeeded\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "if (json && json.data && json.data.email) {",
                  "    pm.collectionVariables.set(\"userEmail\", json.data.email);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{userName}}\",\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{userApiBaseUrl}}/auth/register",
              "host": [
                "{{userApiBaseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Creates a normal ROLE_USER account. Re-running this request with the same email will return the duplicate-email validation error from user-service."
          },
          "response": []
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Login request succeeded\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "if (json && json.data && json.data.token) {",
                  "    pm.collectionVariables.set(\"userToken\", json.data.token);",
                  "}",
                  "if (json && json.data && json.data.user && json.data.user.id) {",
                  "    pm.collectionVariables.set(\"registeredUserId\", String(json.data.user.id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{userApiBaseUrl}}/auth/login",
              "host": [
                "{{userApiBaseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Authenticates the registered user and stores the returned JWT in the `userToken` collection variable."
          },
          "response": []
        },
        {
          "name": "Secure Test Endpoint",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{userToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{userApiBaseUrl}}/test/secure",
              "host": [
                "{{userApiBaseUrl}}"
              ],
              "path": [
                "test",
                "secure"
              ]
            },
            "description": "Simple authenticated smoke test. Through the gateway, the JWT filter injects `X-User-Email` for the user-service controller."
          },
          "response": []
        }
      ]
    },
    {
